<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_form_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_add_sport"
            android:textColor="@color/primary_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:text="@string/label_add_sport_desc"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Name Field -->
        <TextView
            style="@style/FormFieldLabel"
            android:drawableStart="@drawable/ic_search"
            android:text="@string/label_name" />

        <EditText
            android:id="@+id/et_name"
            style="@style/FormFieldInput"
            android:hint="ex: Tennis de Table" />

        <!-- Category Field -->
        <TextView
            style="@style/FormFieldLabel"
            android:drawableStart="@drawable/ic_location"
            android:text="@string/label_location" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/search_bar_bg">

            <AutoCompleteTextView
                android:id="@+id/actv_category"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/search_bar_bg"
                android:inputType="none"
                android:padding="16dp"
                android:text="Courts Intérieurs" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Description Field -->
        <TextView
            style="@style/FormFieldLabel"
            android:drawableStart="@drawable/ic_edit"
            android:text="@string/label_description" />

        <EditText
            android:id="@+id/et_description"
            style="@style/FormFieldInput"
            android:gravity="top"
            android:hint="Décrivez les équipements requis ou les règles spécifiques..."
            android:minLines="4" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/FormFieldLabel"
                    android:drawableStart="@drawable/ic_time"
                    android:text="@string/label_opening" />

                <EditText
                    android:id="@+id/et_opening"
                    style="@style/FormFieldInput"
                    android:hint="08:00 AM" />
            </LinearLayout>

            <View
                android:layout_width="16dp"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/FormFieldLabel"
                    android:drawableStart="@drawable/ic_price"
                    android:text="@string/label_price" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/et_price"
                        style="@style/FormFieldInput"
                        android:hint="45"
                        android:inputType="numberDecimal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:text="€"
                        android:textColor="@color/black"
                        android:textSize="18sp" />
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/FormFieldLabel"
            android:text="IMAGE DE COUVERTURE" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/search_bar_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#CCCCCC"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_add_photo"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Télécharger une photo haute résolution"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_sport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="@string/btn_save"
            android:textAllCaps="false"
            android:textColor="@color/primary_dark"
            app:backgroundTint="@color/accent_lime"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconTint="@color/primary_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_sport"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_cancel"
            android:textAllCaps="false"
            android:textColor="@color/error_red"
            app:cornerRadius="12dp"
            app:strokeColor="#DDDDDD" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
